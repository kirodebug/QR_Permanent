@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DBP – Not Found</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 24px; position: relative; background: linear-gradient(155deg, rgba(10,25,70,0.92) 0%, rgba(30,64,175,0.88) 45%, rgba(15,40,100,0.95) 100%) fixed; }
        .content { text-align: center; max-width: 360px; }
        .icon { font-size: 52px; margin-bottom: 16px; }
        h1 { color: #f1f5f9; font-size: 22px; font-weight: 800; margin-bottom: 8px; }
        p { color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 28px; line-height: 1.6; }
        a { display: inline-block; padding: 13px 28px; background: #2563eb; color: #fff; font-size: 14px; font-weight: 700; border-radius: 12px; text-decoration: none; }
        a:hover { background: #1d4ed8; }
    </style>
</head>
<body>
<div class="content">
    <div class="icon">🔍</div>
    <h1>Employee Not Found</h1>
    <p>No employee record was found for that ID.<br />Please contact your administrator.</p>
    <a href="/generate">← Try Again</a>
</div>
</body>
</html>
